{
  "consumer": {
    "name": "GettingStartedOrderWeb"
  },
  "interactions": [
    {
      "description": "a request for orders",
      "pending": false,
      "providerStates": [
        {
          "name": "there are orders"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/orders"
      },
      "response": {
        "body": {
          "content": [
            {
              "id": 1,
              "items": [
                {
                  "name": "burger",
                  "quantity": 2,
                  "value": 100
                }
              ]
            }
          ],
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json; charset=utf-8"
          ]
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$[*].items": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].items[*].name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].items[*].quantity": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$[*].items[*].value": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          }
        },
        "status": 200
      },
      "type": "Synchronous/HTTP"
    }
  ],
  "metadata": {
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "4.0"
    }
  },
  "provider": {
    "name": "GettingStartedOrderApi"
  }
}